        className="flex-1 h-11 rounded-xl"
        onClick={() => handleSaveDraft(false)}
      >
        Save Draft
      </Button>

    </div>


    <Button
      disabled={creatingInvoice}
      className="w-full h-12 rounded-xl shadow-lg shadow-primary/20"
      onClick={handleCreateInvoice}
    >
      {creatingInvoice
        ? "Creating..."
        : draftId
        ? "Finalize Invoice"
        : "Create Invoice"}
    </Button>

  </CardContent>
</Card>

              </div>
            </div>
          )}
